{
    "name": "hexydec/versions",
    "description": "A list of browser version numbers, along with release dates",
    "type": "library",
    "license": "MIT",
	"autoload": {
		"classmap": ["src/", "dist/", "tests/"]
	},
    "authors": [
        {
            "name": "Hexydec",
            "email": "will@hexydec.com"
        }
    ],
    "minimum-stability": "beta",
    "require": {
        "php": ">=8.4",
        "hexydec/htmldoc": "1.8.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.0"
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=512M"
    }
}
